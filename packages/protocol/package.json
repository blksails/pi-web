{
  "name": "@pi-web/protocol",
  "version": "0.1.0",
  "description": "pi-web 全项目唯一契约根:零运行时依赖(除 zod)、同构、纯 TypeScript 的协议包",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pi-web/logger": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.6"
  }
}
