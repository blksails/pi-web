{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "pi-web",
  "homepage": "https://github.com/earendil-works/pi-web",
  "items": [
    {
      "name": "chat",
      "type": "registry:block",
      "title": "PiChat",
