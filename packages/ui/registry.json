      "dependencies": [
        "@blksails/pi-web-react",
        "ai",
        "@ai-sdk/react",
        "streamdown",
        "lucide-react",
        "@radix-ui/react-dialog",
        "@radix-ui/react-select",
        "class-variance-authority",
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        { "path": "src/chat/pi-chat.tsx", "type": "registry:component" },
        { "path": "src/chat/part-renderer.tsx", "type": "registry:component" },
        { "path": "src/chat/slots.ts", "type": "registry:lib" },
        { "path": "src/parts/pi-tool-part.tsx", "type": "registry:component" },
        { "path": "src/parts/pi-reasoning.tsx", "type": "registry:component" },
        { "path": "src/elements/pi-interaction.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-model-selector.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-thinking-level.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-session-stats.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-command-palette.tsx", "type": "registry:component" },
        { "path": "src/registry/renderer-registry.ts", "type": "registry:lib" },
        { "path": "src/ui/button.tsx", "type": "registry:ui" },
        { "path": "src/ui/card.tsx", "type": "registry:ui" },
        { "path": "src/ui/dialog.tsx", "type": "registry:ui" },
        { "path": "src/ui/select.tsx", "type": "registry:ui" },
        { "path": "src/ui/response.tsx", "type": "registry:ui" },
        { "path": "src/lib/cn.ts", "type": "registry:lib" },
        { "path": "src/styles.css", "type": "registry:style" }
      ]
    },
    {
      "name": "pi-tool-part",
      "type": "registry:component",
      "title": "PiToolPart",
      "description": "工具卡(start/update/end 三态)。",
      "dependencies": ["ai", "lucide-react", "clsx", "tailwind-merge"],
      "files": [
        { "path": "src/parts/pi-tool-part.tsx", "type": "registry:component" },
        { "path": "src/ui/card.tsx", "type": "registry:ui" },
        { "path": "src/lib/cn.ts", "type": "registry:lib" }
      ]
    },
    {
      "name": "pi-reasoning",
      "type": "registry:component",
      "title": "PiReasoning",
      "description": "可折叠思考块。",
      "dependencies": ["ai", "lucide-react", "clsx", "tailwind-merge"],
      "files": [
        { "path": "src/parts/pi-reasoning.tsx", "type": "registry:component" },
        { "path": "src/lib/cn.ts", "type": "registry:lib" }
      ]
    },
    {
      "name": "pi-interaction",
      "type": "registry:component",
      "title": "PiInteraction",
      "description": "扩展 UI 交互内联卡(select/confirm/input/editor + 应答留痕),渲染于消息流末尾。",
      "dependencies": [
        "@blksails/pi-web-react",
        "lucide-react",
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        { "path": "src/elements/pi-interaction.tsx", "type": "registry:component" },
        { "path": "src/ui/card.tsx", "type": "registry:ui" },
        { "path": "src/ui/button.tsx", "type": "registry:ui" },
        { "path": "src/lib/cn.ts", "type": "registry:lib" }
      ]
    },
    {
      "name": "pi-controls",
      "type": "registry:component",
      "title": "Pi controls",
      "description": "PiModelSelector / PiThinkingLevel / PiSessionStats / PiCommandPalette。",
      "dependencies": [
        "@blksails/pi-web-react",
        "@radix-ui/react-select",
        "lucide-react",
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        { "path": "src/controls/pi-model-selector.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-thinking-level.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-session-stats.tsx", "type": "registry:component" },
        { "path": "src/controls/pi-command-palette.tsx", "type": "registry:component" },
        { "path": "src/ui/select.tsx", "type": "registry:ui" },
        { "path": "src/ui/card.tsx", "type": "registry:ui" },
        { "path": "src/lib/cn.ts", "type": "registry:lib" }
