{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app-shell-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "e2e/**/*.ts",
    "next.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "vitest.node-e2e.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "packages", "examples"]
}
