{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@blksails/pi-web-logger": [
        "./packages/logger/src/index.ts"
      ],
      "@blksails/pi-web-agent-kit": [
        "./packages/agent-kit/src/index.ts"
      ],
      "@blksails/pi-web-canvas-kit": [
        "./packages/canvas-kit/src/index.ts"
      ],
      "@blksails/pi-web-primitives": [
        "./packages/primitives/src/index.ts"
      ],
      "@blksails/pi-web-canvas-ui": [
        "./packages/canvas-ui/src/index.ts"
      ],
      "@blksails/pi-web-tool-kit": [
        "./packages/tool-kit/src/index.ts"
      ],
      "@blksails/pi-web-tool-kit/aigc-canvas-schema": [
        "./packages/tool-kit/src/aigc/canvas/schema.ts"
      ],
      "@blksails/pi-web-tool-kit/commands": [
        "./packages/tool-kit/src/commands/index.ts"
      ],
      "@blksails/pi-web-tool-kit/extension-entry": [
        "./packages/tool-kit/src/extension-tools/entry-path.ts"
      ],
      "@blksails/pi-web-tool-kit/auto-title-entry": [
        "./packages/tool-kit/src/auto-title/entry-path.ts"
      ]
    }
  },
  "include": [
    ".next-chrome-test/types/**/*.ts",
    ".next-clear-dev/types/**/*.ts",
    ".next-cli/types/**/*.ts",
    ".next-debug/types/**/*.ts",
    ".next-e2e-on/types/**/*.ts",
    ".next-e2e/types/**/*.ts",
    ".next-probe/types/**/*.ts",
    ".next-ro-dev/types/**/*.ts",
    ".next-stub/types/**/*.ts",
    ".next/types/**/*.ts",
    "app-shell-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "e2e/**/*.ts",
    "lib/**/*.ts",
    "next-env.d.ts",
    "next.config.ts",
    "playwright.config.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vitest.config.ts",
    "vitest.node-e2e.config.ts",
    ".next-hr/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "server/**/*.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "packages",
    "examples",
    "spike"
  ]
}
