# pi-web app shell — environment configuration sample.
# Copy to `.env.local` and fill in. Values are read at runtime by lib/app/config.ts
# and are NEVER logged, echoed to the client, or placed in error responses.

# ── Credentials & defaults come from ~/.pi/agent by default ───────────────────
# pi-web spawns the agent process (custom-agent runner or `pi --mode rpc`), which
# reads your pi config dir:
#   ~/.pi/agent/auth.json     → API keys / OAuth tokens stored by `pi` login
#   ~/.pi/agent/settings.json → default provider/model, installed packages, theme
# So if you've run `pi` and logged in, NO env provider key is required, and the
# default model/provider come from settings.json (the UI honors your pi config).

# ── Provider API keys (OPTIONAL, additive passthrough) ────────────────────────
# Only needed to override / supplement ~/.pi/agent/auth.json. Passed through to
# the agent process via env. Leave blank to rely on auth.json.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=

# ── pi config dir override (OPTIONAL) ─────────────────────────────────────────
# Defaults to ~/.pi/agent. Set to isolate per-tenant config (auth/settings/sessions).
# PI_WEB_AGENT_DIR=/abs/path/to/agent-dir
# (PI_CODING_AGENT_DIR is also honored, matching pi's own env var.)

# ── Session-creation defaults (OPTIONAL overrides) ────────────────────────────
# Leave UNSET to let ~/.pi/agent/settings.json decide the provider/model.
# Set only to force a specific model regardless of settings.json.
# PI_WEB_DEFAULT_PROVIDER=openrouter
# PI_WEB_DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# Hide specific providers from the settings model/provider dropdown (OPTIONAL).
# Comma-separated provider names; their models are filtered out of the
# GET /config/models data endpoint, so they never appear in the UI dropdown.
# PI_WEB_HIDE_PROVIDERS=anthropic,openai

# Default agent source offered by the picker (a directory with index.ts for a
# custom agent, any directory for general CLI mode, or a git source).
# PI_WEB_DEFAULT_SOURCE=./examples/hello-agent

# Default working directory for sessions (defaults to the server cwd).
# PI_WEB_DEFAULT_CWD=

# ── e2e / offline ────────────────────────────────────────────────────────────
# Set to 1 to run every session against a deterministic local stub agent that
# speaks the RPC JSONL protocol. No API key required. Used by Playwright e2e and
# the Node-level streaming e2e for offline determinism.
# PI_WEB_STUB_AGENT=1

# 视觉识别默认模型（image_vision）。格式 provider/modelId，须在 models.json 中且 input 含 image。
# 建议始终配置：无人值守通道（IM/定时任务）hasUI 亦为 true，不配会弹层等人点选而永久挂起。
# PI_WEB_VISION_MODEL=apiservices/gpt-5.4

# ── ai-gateway providers (OPTIONAL, spec ai-gateway-providers) ────────────────
# Single enable switch: setting AI_GATEWAY_BASE_URL mounts /api/ai-gateway/*
# (key-exchange forwarding), aggregates the gateway model catalog, and adds the
# gateway AIGC image routes. Unset/blank = fully disabled (zero registration).
# Restart dev after changing (handler singleton is pinned in globalThis).
# AI_GATEWAY_BASE_URL=http://127.0.0.1:8080
# Platform sk-gw key, read per-request (swap in place without restart).
# AI_GATEWAY_API_KEY=
# Signing secret for scope="ai-gateway" session tokens. REQUIRED when enabled
# unless PI_WEB_ATTACHMENT_SECRET is set (assembly fails fast otherwise).
# PI_WEB_AI_GATEWAY_SECRET=
# Optional overrides (defaults in packages/server/src/ai-gateway/config.ts):
# AI_GATEWAY_TIMEOUT_MS=120000
# AI_GATEWAY_CATALOG_TTL_MS=300000
# PI_WEB_AI_GATEWAY_MODEL_PRECEDENCE=gateway   # duplicate-name winner: gateway | self
# Only needed for e2b sandboxes to reach ai-gateway (sandbox-reachable base):
# PI_WEB_LLM_GATEWAY_PUBLIC_BASE=
