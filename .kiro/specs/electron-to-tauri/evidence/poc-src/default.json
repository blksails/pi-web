{
  "$schema": "../gen/schemas/remote-schema.json",
  "identifier": "poc-remote",
  "description": "允许本地回环远端页面调用 core 命令",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://127.0.0.1:*/*",
      "http://localhost:*",
      "http://localhost:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-ping"
  ]
}