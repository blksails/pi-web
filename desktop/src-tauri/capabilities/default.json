{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "pi-web-desktop",
  "description": "pi-web 桌面壳：允许本地回环远端页面调用受控的宿主命令",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://127.0.0.1:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-pick-directory",
    "allow-retry",
    "allow-quit",
    "allow-store-credential",
    "allow-load-credential",
    "allow-clear-credential",
    "allow-pane-relay-host"
  ]
}
