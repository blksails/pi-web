{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pi-web",
  "version": "0.1.3",
  "identifier": "com.blksails.pi-web-desktop",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage"],
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "pi-web 桌面版",
    "externalBin": ["binaries/node"],
    "resources": {
      "../../dist/": "dist/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
