{
  "name": "@blksails/pi-web",
  "version": "0.1.3",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "pi-web": "bin/pi-web.mjs"
  },
  "files": [
    "bin",
    "dist",
    "vite.config.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:dist",
    "build:client": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "build:dist": "pnpm build:client && pnpm build:server && node scripts/pack-dist.mjs",
    "start:dist": "node dist/server.mjs",
    "dev:server": "node --import ./node_modules/.pnpm/jiti@2.7.0/node_modules/jiti/lib/jiti-register.mjs server/index.ts",
    "start": "node dist/server.mjs",
    "build:cli": "pnpm build:dist",
    "start:cli": "node bin/pi-web.mjs",
    "e2e:cli": "node e2e/cli/cli-smoke.mjs",
    "e2e:cli:watch": "node e2e/cli/cli-watch.mjs",
    "e2e:cli:real": "node e2e/cli/cli-real.mjs",
    "e2e:cli:reloc": "node e2e/cli/cli-reloc.mjs",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "test:app": "vitest run",
    "e2e": "playwright test",
    "e2e:build": "pnpm build:dist && playwright test",
    "e2e:node": "cross-env PI_WEB_STUB_AGENT=1 vitest run -c vitest.node-e2e.config.ts",
    "e2e:csp": "node e2e/csp/import-map-csp.mjs",
    "typecheck": "pnpm -r run typecheck && tsc -p tsconfig.json --noEmit",
    "e2e:desktop:real": "node e2e/desktop/desktop-real.mjs",
    "e2e:desktop:nonode": "node e2e/desktop/desktop-no-node.mjs",
    "e2e:desktop:packaged": "node e2e/desktop/desktop-packaged.mjs",
    "desktop:sidecar": "node scripts/fetch-node-sidecar.mjs",
    "desktop:baseline": "node scripts/measure-desktop-baseline.mjs",
    "desktop:build": "pnpm --filter @blksails/pi-web-desktop exec tauri build",
    "e2e:desktop:webdriver": "node e2e/desktop/webdriver/bridge.e2e.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@blksails/pi-web-canvas-ui": "workspace:*",
    "@blksails/pi-web-kit": "workspace:*",
    "@blksails/pi-web-logger": "workspace:*",
    "@blksails/pi-web-protocol": "workspace:*",
    "@blksails/pi-web-react": "workspace:*",
    "@blksails/pi-web-server": "workspace:*",
    "@blksails/pi-web-tool-kit": "workspace:*",
    "@blksails/pi-web-ui": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "ai": "^5.0.0",
    "hono": "^4.12.28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6",
    "vitest": "^2.1.8"
  },
  "description": "pi web — 全局可安装 CLI，拉起 Next standalone 自包含产物",
  "publishConfig": {
    "access": "public"
  }
}
